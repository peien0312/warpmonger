SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development

# ===========================================
# Shopping List Contact Configuration
# ===========================================

# Email Configuration (for sending shopping list via email)
# Using Gmail: Enable 2FA and create an App Password at https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SHOP_EMAIL=shop-owner@email.com

# Telegram Configuration
# Your Telegram username (without @) - users will be directed to t.me/YOUR_USERNAME
TELEGRAM_USERNAME=your_telegram_username

# LINE Configuration
# Your LINE Official Account ID (with @) - users will be directed to add your account
# Get this from LINE Official Account Manager: https://manager.line.biz/
# Format: @youraccountid
LINE_ID=@your_line_official_account_id

# ===========================================
# PayUni 統一金流 (default online payment: 信用卡/Apple・Google Pay/ATM/超商代碼)
# ===========================================
# From the PayUni merchant console. HASH_KEY/HASH_IV encrypt+sign the UPP
# payload (AES-256-GCM). Set PAYUNI_SANDBOX=1 for the test environment.
PAYUNI_MER_ID=your-payuni-merchant-id
PAYUNI_HASH_KEY=your-payuni-hash-key
PAYUNI_HASH_IV=your-payuni-hash-iv
PAYUNI_SANDBOX=1

# ===========================================
# Optional operations
# ===========================================
# Sentry error monitoring (leave blank to disable)
SENTRY_DSN=
# Send session cookies only over HTTPS (default on; set 0 for local http)
SESSION_COOKIE_SECURE=1
